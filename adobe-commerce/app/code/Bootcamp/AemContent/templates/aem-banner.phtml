<div class="aem-banner <?php echo $block->isAemLive() ? 'aem-banner--live' : 'aem-banner--fallback'; ?>">
    <?php if ($block->hasBanner()): ?>
        <?php $bannerContent = $block->getBannerContent(); ?>
        
        <div class="aem-banner__container">
            <?php if ($bannerContent['image_url']): ?>
                <div class="aem-banner__image">
                    <img src="<?php echo $this->escapeUrl($bannerContent['image_url']); ?>"
                         alt="<?php echo $this->escapeHtml($bannerContent['title']); ?>">
                </div>
            <?php endif; ?>
            
            <div class="aem-banner__content">
                <h2 class="aem-banner__title">
                    <?php echo $this->escapeHtml($bannerContent['title']); ?>
                </h2>
                
                <p class="aem-banner__description">
                    <?php echo $this->escapeHtml($bannerContent['description']); ?>
                </p>
                
                <?php if ($bannerContent['cta_url'] && $bannerContent['cta_url'] !== '#'): ?>
                    <a href="<?php echo $this->escapeUrl($bannerContent['cta_url']); ?>"
                       class="aem-banner__cta">
                        <?php echo $this->escapeHtml($bannerContent['cta_text']); ?>
                    </a>
                <?php endif; ?>
            </div>
            
            <?php if (!$block->isAemLive()): ?>
                <div class="aem-banner__warning">
                    ⚠️ Conteúdo em modo fallback (AEM offline)
                </div>
            <?php endif; ?>
        </div>
    <?php endif; ?>
</div>

