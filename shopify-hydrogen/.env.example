# Variáveis de Ambiente para Shopify Hydrogen
# Copie este arquivo para .env.local e preencha com seus valores

# Shopify Storefront API
PUBLIC_STOREFRONT_API_TOKEN=sua_storefront_api_token_aqui
PUBLIC_STORE_DOMAIN=sua-loja.myshopify.com

# Sessão
SESSION_SECRET=bootcamp-secret-key-2026-change-this

# AEM (Opcional - para integração)
PRIVATE_AEM_AUTHOR_URL=http://localhost:4502
PRIVATE_AEM_USERNAME=admin
PRIVATE_AEM_PASSWORD=admin

# Commerce (Opcional - para integração)
PRIVATE_COMMERCE_API_URL=https://app.magento2.test/rest/V1
PRIVATE_COMMERCE_API_TOKEN=seu_commerce_token_aqui

# Environment
ENV=development
DEBUG=true
